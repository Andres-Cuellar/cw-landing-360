---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href="/icono.webp" />
		<link rel="icon" href="/icono.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>Creamos tu web</title>
	</head>
	<body>
		<slot />

		<!-- Floating WhatsApp button -->
		<a
			href="https://wa.me/18885453113?text=Quiero%20hablar%20con%20un%20asesor%20360"
			target="_blank"
			rel="noopener noreferrer"
			class="wa-float"
			aria-label="Hablar por WhatsApp"
		>
			<span class="wa-pulse"></span>
			<svg class="wa-icon" width="28" height="28" viewBox="0 0 32 32" fill="currentColor">
				<path d="M16 2a14 14 0 0 0-12.19 20.89L2 30l7.3-1.78A14 14 0 1 0 16 2zm0 25.5a11.44 11.44 0 0 1-5.84-1.6l-.42-.25-4.33 1.05 1.08-4.22-.28-.44A11.5 11.5 0 1 1 16 27.5zm6.29-8.56c-.34-.17-2.03-1-2.34-1.11s-.54-.17-.77.17-.88 1.11-1.08 1.34-.4.26-.74.09a9.32 9.32 0 0 1-2.74-1.69 10.3 10.3 0 0 1-1.9-2.36c-.2-.34 0-.52.15-.69s.34-.4.51-.6a2.27 2.27 0 0 0 .34-.57.63.63 0 0 0 0-.6c-.09-.17-.77-1.85-1.05-2.53s-.56-.57-.77-.58h-.65a1.26 1.26 0 0 0-.91.43 3.84 3.84 0 0 0-1.2 2.85 6.67 6.67 0 0 0 1.4 3.54c.17.23 2.4 3.66 5.82 5.13a19.6 19.6 0 0 0 1.94.72 4.67 4.67 0 0 0 2.14.13c.65-.1 2.03-.83 2.32-1.63a2.87 2.87 0 0 0 .2-1.63c-.08-.14-.31-.23-.65-.4z"/>
			</svg>
		</a>

		<style is:global>
			.wa-float {
				position: fixed;
				bottom: 28px;
				right: 28px;
				z-index: 9999;
				display: flex;
				align-items: center;
				justify-content: center;
				background: #25d366;
				color: #fff;
				text-decoration: none;
				border-radius: 50%;
				width: 56px;
				height: 56px;
				box-shadow: 0 4px 20px rgba(37, 211, 102, 0.45);
				transition: box-shadow 0.2s, transform 0.2s;
			}
			.wa-float:hover {
				box-shadow: 0 8px 28px rgba(37, 211, 102, 0.5);
				transform: translateY(-2px);
			}
			.wa-pulse {
				position: absolute;
				inset: 0;
				border-radius: 50px;
				background: #25d366;
				animation: wa-pulse 2.5s ease-out infinite;
				z-index: -1;
			}
			@keyframes wa-pulse {
				0%   { transform: scale(1); opacity: 0.6; }
				70%  { transform: scale(1.18); opacity: 0; }
				100% { transform: scale(1.18); opacity: 0; }
			}
			.wa-icon {
				flex-shrink: 0;
				width: 28px;
				height: 28px;
			}
			@media (max-width: 480px) {
				.wa-float {
					bottom: 20px;
					right: 16px;
					width: 50px;
					height: 50px;
				}
			}
		</style>
	</body>
</html>
