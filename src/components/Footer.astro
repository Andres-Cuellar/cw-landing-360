---
import logo from "../assets/logo.webp";
---

<footer class="footer-section">
  <div class="container">
    <div class="footer-top">
      <!-- Brand & Info -->
      <div class="footer-brand">
        <a href="/" class="logo">
          <img src={logo.src} alt="Creamos tu web Logo" class="logo-black" />
        </a>
        <p class="brand-desc">
          Construimos tu Ecosistema de Ventas Todo en Uno. Embudos, CRM y
          automatizaciones de WhatsApp listas para operar, sin que toques una
          sola línea de código.
        </p>
        <div class="social-links">
          <a href="http://facebook.com/creamostuweb.co" class="social-btn" aria-label="Facebook">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
              ></path>
            </svg>
          </a>
          <a href="http://instagram.com/creamostuweb.co" class="social-btn" aria-label="Instagram">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"
              ></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
              ></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="https://www.tiktok.com/@creamostuweb" class="social-btn" aria-label="TikTok">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.26 8.26 0 0 0 4.83 1.54V6.78a4.85 4.85 0 0 1-1.06-.09z"/>
            </svg>
          </a>
    
        </div>
      </div>

      <!-- Company Links -->
      <div class="footer-links-col">
        <h4 class="col-title">ENLACES</h4>
        <ul class="link-list">
          <li><a href="#inicio">Inicio</a></li>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#portafolio">Portafolio</a></li>
          <li><a href="#testimonios">Testimonios</a></li>
          <li><a href="#faq">Preguntas frecuentes</a></li>
        </ul>
      </div>

      <!-- Services Links -->
      <div class="footer-links-col">
        <h4 class="col-title">SERVICES</h4>
        <ul class="link-list">
          <li><a href="#">Web Design</a></li>
          <li><a href="#">Mobile Apps</a></li>
          <li><a href="#">UI/UX Design</a></li>
          <li><a href="#">Brand Identity</a></li>
          <li><a href="#">ERP Systems</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="footer-newsletter">
        <h4 class="col-title">MANTENTE AL DIA</h4>
        <p class="news-text">
          Obten nuestros últimos artículos, estudios de caso y noticias de
          productos entregados a tu bandeja de entrada.
        </p>
        <form class="subscribe-form">
          <input type="email" placeholder="your@email.com" class="sub-input" />
          <button type="submit" class="btn-sub">Suscribete</button>
        </form>
      </div>
    </div>

    <!-- Bottom Line -->
    <div class="footer-bottom">
      <p class="copyright">&copy; 2026 Creamos tu web. All rights reserved.</p>
      <div class="legal-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    width: 100%;
    display: flex;
    justify-content: center;
    background-color: var(--clr-bg);
    font-family: "Plus Jakarta Sans", sans-serif;
    padding-top: 80px;
  }

  .container {
    max-width: 1120px;
    width: 100%;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    padding-bottom: 60px;
  }

  /* Brand Col */
  .footer-brand {
    flex: 2;
    max-width: 320px;
    display: flex;
    flex-direction: column;
  }

  .logo {
    text-decoration: none;
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 24px;
    display: inline-block;
  }

  .logo img {
    max-width: 250px;
    height: auto;
  }

  .brand-desc {
    color: var(--clr-text-3);
    font-size: 14.5px;
    line-height: 1.6;
    margin: 0 0 32px 0;
  }

  .social-links {
    display: flex;
    gap: 12px;
  }

  .social-btn {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    border: 1px solid var(--clr-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-text-3);
    transition: all 0.2s;
    text-decoration: none;
  }

  .social-btn:hover {
    border-color: var(--clr-text);
    color: var(--clr-text);
    background-color: var(--clr-bg-subtle);
  }

  /* Links Cols */
  .footer-links-col {
    flex: 1;
  }

  .col-title {
    color: var(--clr-text);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.05em;
    margin: 0 0 24px 0;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .link-list a {
    color: var(--clr-text-3);
    text-decoration: none;
    font-size: 14.5px;
    font-weight: 500;
    transition: color 0.2s;
  }

  .link-list a:hover {
    color: var(--clr-text);
  }

  /* Newsletter Col */
  .footer-newsletter {
    flex: 2;
    max-width: 320px;
  }

  .news-text {
    color: var(--clr-text-3);
    font-size: 14.5px;
    line-height: 1.6;
    margin: 0 0 20px 0;
  }

  .subscribe-form {
    display: flex;
    gap: 12px;
  }

  .sub-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--clr-border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    color: var(--clr-text);
    outline: none;
    transition: border-color 0.2s;
  }

  .sub-input:focus {
    border-color: var(--clr-text);
  }

  .btn-sub {
    background-color: var(--clr-void);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0 24px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: background-color 0.2s;
  }

  .btn-sub:hover {
    background-color: var(--clr-surface-input);
  }

  /* Bottom Line */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    border-top: 1px solid var(--clr-bg-muted);
  }

  .copyright {
    color: var(--clr-text-5);
    font-size: 13px;
    margin: 0;
  }

  .legal-links {
    display: flex;
    gap: 24px;
  }

  .legal-links a {
    color: var(--clr-text-5);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s;
  }

  .legal-links a:hover {
    color: var(--clr-text-3);
  }

  @media (max-width: 1024px) {
    .footer-top {
      flex-wrap: wrap;
    }
    .footer-brand {
      flex: 100%;
      max-width: 100%;
      margin-bottom: 20px;
    }
    .footer-newsletter {
      flex: 100%;
      max-width: 100%;
      margin-top: 20px;
    }
  }

  @media (max-width: 600px) {
    .footer-bottom {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
    .subscribe-form {
      flex-direction: column;
    }
    .btn-sub {
      padding: 12px;
    }
  }
</style>
